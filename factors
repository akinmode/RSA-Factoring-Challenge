#!/usr/bin/python3
from sys import argv

def factorize(num):
    """
        Factorize as many numbers as possible into a product of two smaller numbers.
    """
    multifactor = 2

    if num < 2:
        return
    else:
        while num % multifactor:
            multifactor += 1
        print("{:.0f}={:.0f}*{:.0f}".format(num, num / multifactor, multifactor))

if len(argv) != 2:
    exit()
else:
    try:
        with open(argv[1]) as file:
            rows = file.read().split('\n')
            for num in rows:
                if num != "":
                    factorize(int(num))
    except Exception as e:
        print(str(e))
